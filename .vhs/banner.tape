Output ../docs/banner.gif

Set FontSize 14
Set Width 1400
Set Height 360
Set Theme "Catppuccin Mocha"
Set Padding 30
Set TypingSpeed 0ms

Hide
Type "clear && figlet -f slant 'claude-secrets' | lolcat -f -F 0.15"
