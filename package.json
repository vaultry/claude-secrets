{
  "name": "@vaultry/claude-secrets",
  "version": "0.1.5",
  "description": "Encrypted secrets store for Claude Code (MCP) + CLI + .env placeholder expansion. macOS Keychain backed.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Joris Slagter <mail@jorisslagter.nl>",
  "homepage": "https://github.com/vaultry/claude-secrets",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaultry/claude-secrets.git"
  },
  "bugs": {
    "url": "https://github.com/vaultry/claude-secrets/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "model-context-protocol",
    "secrets",
    "keychain",
    "macos",
    "dotenv",
    "cli",
    "encrypted"
  ],
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "claude-secrets-mcp": "dist/index.js",
    "claude-secrets-setup": "dist/bin/setup.js",
    "claude-secrets": "dist/bin/cli.js",
    "claude-secrets-session-hook": "dist/bin/session-hook.js"
  },
  "files": [
    "dist",
    "commands",
    "docs",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/bin/setup.js dist/bin/cli.js dist/bin/session-hook.js",
    "dev": "tsc -w",
    "start": "node dist/index.js",
    "setup": "node dist/bin/setup.js",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
